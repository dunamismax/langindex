---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contribute" description="Contribute to LangIndex.">
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <h1 class="text-3xl font-semibold text-stone-950">Contribute</h1>
    <div class="content-body mt-6 text-stone-700">
      <p>
        Contributions should separate facts from judgment, cite claims that are
        not obvious from official resources, and keep examples small and
        idiomatic.
      </p>
      <p>
        Start with the repository contribution guide, then open a pull request
        with focused changes.
      </p>
      <p>
        New language and comparison pages should start from the repository
        templates and follow the source guidance.
      </p>
      <p>
        <a
          class="font-medium text-teal-800 underline-offset-4 hover:underline"
          href="https://github.com/dunamismax/langindex/blob/main/CONTRIBUTING.md"
          >Read CONTRIBUTING.md</a
        >
        <span aria-hidden="true"> / </span>
        <a
          class="font-medium text-teal-800 underline-offset-4 hover:underline"
          href="https://github.com/dunamismax/langindex/tree/main/docs/templates"
          >Use templates</a
        >
      </p>
    </div>
  </section>
</BaseLayout>
