---
import BaseLayout from "../layouts/BaseLayout.astro";

const steps = [
  {
    title: "Find or open an issue",
    body: "Open an issue describing the change. Even a one-line correction benefits from a paper trail.",
  },
  {
    title: "Start from a template",
    body: "Language and comparison pages have repository templates. They keep frontmatter and source sections consistent.",
  },
  {
    title: "Cite anything non-obvious",
    body: "Prefer official sources. Mark unknowns directly. Never imply a source was checked when it was not.",
  },
  {
    title: "Open a pull request",
    body: "Keep PRs focused: one language, one comparison, or one decision per change.",
  },
];
---

<BaseLayout title="Contribute" description="Contribute to LangIndex.">
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
    >
      Contribute
    </p>
    <h1
      class="mt-2 text-3xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] sm:text-4xl"
    >
      Help maintain a language page
    </h1>
    <p class="mt-4 text-lg leading-8 text-[color:var(--color-fg-muted)]">
      Contributions should separate facts from judgment, cite claims that are
      not obvious from official resources, and keep examples small and
      idiomatic.
    </p>

    <ol class="mt-10 space-y-4">
      {
        steps.map((step, index) => (
          <li class="flex gap-4 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-4">
            <span
              aria-hidden="true"
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-[color:var(--color-border-strong)] bg-[color:var(--color-surface-muted)] font-mono text-sm font-semibold text-[color:var(--color-accent)]"
            >
              {String(index + 1).padStart(2, "0")}
            </span>
            <div>
              <h2 class="text-base font-semibold text-[color:var(--color-fg-strong)]">
                {step.title}
              </h2>
              <p class="mt-1 text-sm leading-6 text-[color:var(--color-fg-muted)]">
                {step.body}
              </p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="mt-10 flex flex-wrap gap-3">
      <a
        class="inline-flex items-center gap-1.5 rounded-md bg-[color:var(--color-accent)] px-4 py-2 text-sm font-semibold text-[color:var(--color-accent-fg)] transition-opacity hover:opacity-90"
        href="https://github.com/dunamismax/langindex/blob/main/CONTRIBUTING.md"
        rel="noopener"
      >
        Read CONTRIBUTING.md
      </a>
      <a
        class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-2 text-sm font-semibold text-[color:var(--color-fg)] hover:border-[color:var(--color-border-strong)]"
        href="https://github.com/dunamismax/langindex/tree/main/docs/templates"
        rel="noopener"
      >
        Use templates
      </a>
      <a
        class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-2 text-sm font-semibold text-[color:var(--color-fg)] hover:border-[color:var(--color-border-strong)]"
        href="https://github.com/dunamismax/langindex/issues"
        rel="noopener"
      >
        Browse issues
      </a>
    </div>
  </section>
</BaseLayout>
