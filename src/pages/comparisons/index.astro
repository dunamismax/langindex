---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const comparisons = (await getCollection("comparisons")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout
  title="Comparisons"
  description="Programming language comparisons on LangIndex."
>
  <section class="mx-auto max-w-6xl px-4 pt-10 pb-4 sm:px-6">
    <p
      class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
    >
      Index
    </p>
    <h1
      class="mt-2 text-3xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] sm:text-4xl"
    >
      Comparisons
    </h1>
    <p class="mt-3 max-w-2xl text-[color:var(--color-fg-muted)]">
      Dimensional comparisons focused on fit and tradeoffs, not winners.
    </p>
  </section>
  <section class="mx-auto max-w-6xl px-4 pt-6 pb-12 sm:px-6">
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        comparisons.map((comparison) => (
          <article class="group relative overflow-hidden rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5 transition-colors hover:border-[color:var(--color-accent)]/60">
            <a
              href={`/comparisons/${comparison.data.slug}`}
              class="absolute inset-0"
              aria-label={`Open ${comparison.data.title}`}
            />
            <h2 class="text-lg font-semibold tracking-tight text-[color:var(--color-fg-strong)] group-hover:text-[color:var(--color-accent)]">
              {comparison.data.title}
            </h2>
            <p class="mt-2 text-sm leading-6 text-[color:var(--color-fg-muted)]">
              {comparison.data.summary}
            </p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {comparison.data.languages.map((language) => (
                <span class="rounded-full bg-[color:var(--color-surface-muted)] px-2 py-0.5 text-[0.7rem] text-[color:var(--color-fg-muted)]">
                  {language}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
