---
import { getCollection, render } from "astro:content";
import SourceList from "../../components/layout/SourceList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const comparisons = await getCollection("comparisons");
  return comparisons.map((comparison) => ({
    params: { slug: comparison.data.slug },
    props: { comparison },
  }));
}

const { comparison } = Astro.props;
const { Content } = await render(comparison);
const languages = await getCollection("languages");
const languageTitles = new Map(
  languages.map((entry) => [entry.data.slug, entry.data.title]),
);
const pendingLanguageTitles: Record<string, string> = {
  c: "C",
  cpp: "C++",
  csharp: "C#",
  dart: "Dart",
  java: "Java",
  javascript: "JavaScript",
  kotlin: "Kotlin",
  python: "Python",
  zig: "Zig",
};
---

<BaseLayout title={comparison.data.title} description={comparison.data.summary}>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <nav
      aria-label="Breadcrumb"
      class="text-sm text-[color:var(--color-fg-subtle)]"
    >
      <a class="hover:text-[color:var(--color-fg)]" href="/comparisons"
        >Comparisons</a
      >
      <span aria-hidden="true" class="px-1.5">/</span>
      <span class="text-[color:var(--color-fg-muted)]"
        >{comparison.data.title}</span
      >
    </nav>
    <p
      class="mt-6 text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
    >
      Comparison
    </p>
    <h1
      class="mt-2 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]"
    >
      {comparison.data.title}
    </h1>
    <p
      class="mt-4 text-lg leading-8 text-[color:var(--color-fg-muted)]"
      data-pagefind-meta="summary"
    >
      {comparison.data.summary}
    </p>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <span class="text-xs text-[color:var(--color-fg-subtle)]">Languages:</span
      >
      {
        comparison.data.languages.map((slug) =>
          languageTitles.has(slug) ? (
            <a
              href={`/languages/${slug}`}
              class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-2.5 py-1 text-xs font-medium text-[color:var(--color-fg)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
            >
              {languageTitles.get(slug)}
            </a>
          ) : (
            <span class="rounded-full border border-dashed border-[color:var(--color-border)] px-2.5 py-1 text-xs font-medium text-[color:var(--color-fg-subtle)]">
              {pendingLanguageTitles[slug] ?? slug}
            </span>
          ),
        )
      }
    </div>
    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-filter="type">Comparison</span>
      {
        comparison.data.languages.map((language) => (
          <span data-pagefind-filter="language">{language}</span>
        ))
      }
      {
        comparison.data.useCases.map((useCase) => (
          <span data-pagefind-filter="use case">{useCase}</span>
        ))
      }
    </div>
    <div class="content-body mt-10">
      <Content />
    </div>
    <SourceList
      sources={comparison.data.sources}
      lastVerified={comparison.data.lastVerified}
    />
  </article>
</BaseLayout>
