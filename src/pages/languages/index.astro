---
import { getCollection } from "astro:content";
import LanguageCard from "../../components/language/LanguageCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const languages = (await getCollection("languages")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const normalize = (value: string) => value.trim().toLowerCase();
const unique = (values: string[]) =>
  Array.from(new Set(values.map(normalize))).sort((a, b) => a.localeCompare(b));
const useCaseRules = [
  { label: "cli tools", terms: ["command-line", "scripts"] },
  { label: "infrastructure", terms: ["infrastructure", "distributed"] },
  { label: "network services", terms: ["network services", "services"] },
  { label: "systems software", terms: ["systems software", "embedded"] },
  { label: "web applications", terms: ["web", "node.js", "javascript"] },
];
const useCaseTags = (items: string[]) => {
  const text = items.join(" ").toLowerCase();
  return useCaseRules
    .filter((rule) => rule.terms.some((term) => text.includes(term)))
    .map((rule) => rule.label);
};

const paradigms = unique(
  languages.flatMap((language) => language.data.paradigms),
);
const typings = unique(
  languages.flatMap((language) => [
    language.data.typing.discipline,
    language.data.typing.strength ?? "",
  ]),
).filter(Boolean);
const runtimes = unique(
  languages.map((language) => language.data.runtime.model),
);
const ecosystems = unique(
  languages.flatMap((language) => language.data.packageManagers),
);
const useCases = unique(
  languages.flatMap((language) => useCaseTags(language.data.bestFor)),
);
---

<BaseLayout
  title="Languages"
  description="Browse programming language profiles on LangIndex."
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <h1 class="text-3xl font-semibold text-stone-950">Languages</h1>
    <p class="mt-3 max-w-2xl text-stone-700">
      Browse language profiles by practical fit, runtime, memory model, typing,
      tooling, and verified sources.
    </p>

    <form
      class="mt-8 grid gap-4 rounded-lg border border-stone-200 bg-white p-4 md:grid-cols-3"
      data-language-filters
    >
      <label class="block text-sm font-medium text-stone-950">
        Search
        <input
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          type="search"
          name="q"
          placeholder="Rust, garbage collected, web..."
          data-filter-search
        />
      </label>
      <label class="block text-sm font-medium text-stone-950">
        Paradigm
        <select
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          name="paradigm"
          data-filter-field
        >
          <option value="">Any paradigm</option>
          {paradigms.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-stone-950">
        Typing
        <select
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          name="typing"
          data-filter-field
        >
          <option value="">Any typing</option>
          {typings.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-stone-950">
        Runtime target
        <select
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          name="runtime"
          data-filter-field
        >
          <option value="">Any runtime</option>
          {runtimes.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-stone-950">
        Ecosystem
        <select
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          name="ecosystem"
          data-filter-field
        >
          <option value="">Any ecosystem</option>
          {ecosystems.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <label class="block text-sm font-medium text-stone-950">
        Use case
        <select
          class="mt-2 w-full rounded-md border border-stone-300 bg-white px-3 py-2 text-base text-stone-950"
          name="useCase"
          data-filter-field
        >
          <option value="">Any use case</option>
          {useCases.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <div class="flex items-end justify-between gap-4 md:col-span-3">
        <p class="text-sm text-stone-600" aria-live="polite" data-filter-count>
          Showing {languages.length} languages
        </p>
        <button
          class="rounded-md border border-stone-300 px-3 py-2 text-sm font-medium text-stone-800 hover:bg-stone-100"
          type="reset"
        >
          Reset
        </button>
      </div>
    </form>

    <div class="mt-8 grid gap-4 md:grid-cols-2" data-language-results>
      {
        languages.map((language) => {
          const typingValues = [
            language.data.typing.discipline,
            language.data.typing.strength ?? "",
          ]
            .filter(Boolean)
            .map(normalize);
          const searchText = [
            language.data.title,
            language.data.summary,
            ...language.data.paradigms,
            ...typingValues,
            language.data.runtime.model,
            language.data.memory.model,
            ...language.data.packageManagers,
            ...language.data.bestFor,
            ...language.data.poorFit,
          ]
            .join(" ")
            .toLowerCase();

          return (
            <div
              data-language-card
              data-search={searchText}
              data-paradigm={language.data.paradigms.map(normalize).join("|")}
              data-typing={typingValues.join("|")}
              data-runtime={normalize(language.data.runtime.model)}
              data-ecosystem={language.data.packageManagers
                .map(normalize)
                .join("|")}
              data-use-case={useCaseTags(language.data.bestFor)
                .map(normalize)
                .join("|")}
            >
              <LanguageCard language={language} />
            </div>
          );
        })
      }
    </div>
    <p class="mt-6 hidden text-sm text-stone-600" data-filter-empty>
      No languages match those filters yet.
    </p>
  </section>

  <script>
    const form = document.querySelector("[data-language-filters]");
    const cards = Array.from(document.querySelectorAll("[data-language-card]"));
    const count = document.querySelector("[data-filter-count]");
    const empty = document.querySelector("[data-filter-empty]");

    const splitValues = (value: string | undefined) =>
      (value ?? "").split("|").filter(Boolean);

    const matches = (card: Element, key: string, selected: string) =>
      !selected ||
      splitValues((card as HTMLElement).dataset[key]).includes(selected);

    const applyFilters = () => {
      if (!(form instanceof HTMLFormElement)) return;
      const data = new FormData(form);
      const query = String(data.get("q") ?? "")
        .trim()
        .toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const element = card as HTMLElement;
        const isVisible =
          (!query || (element.dataset.search ?? "").includes(query)) &&
          matches(card, "paradigm", String(data.get("paradigm") ?? "")) &&
          matches(card, "typing", String(data.get("typing") ?? "")) &&
          matches(card, "runtime", String(data.get("runtime") ?? "")) &&
          matches(card, "ecosystem", String(data.get("ecosystem") ?? "")) &&
          matches(card, "useCase", String(data.get("useCase") ?? ""));

        element.hidden = !isVisible;
        if (isVisible) visible += 1;
      });

      if (count) {
        count.textContent = `Showing ${visible} ${
          visible === 1 ? "language" : "languages"
        }`;
      }
      empty?.classList.toggle("hidden", visible !== 0);
    };

    form?.addEventListener("input", applyFilters);
    form?.addEventListener("reset", () => window.setTimeout(applyFilters, 0));
  </script>
</BaseLayout>
