---
import { getCollection, render } from "astro:content";
import SourceList from "../../components/layout/SourceList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const languages = await getCollection("languages");
  return languages.map((language) => ({
    params: { slug: language.data.slug },
    props: { language },
  }));
}

const { language } = Astro.props;
const { Content } = await render(language);
const data = language.data;
const allLanguages = await getCollection("languages");
const comparisons = await getCollection("comparisons");
const languageTitles = new Map(
  allLanguages.map((entry) => [entry.data.slug, entry.data.title]),
);
const comparisonMatches = comparisons
  .filter((comparison) => comparison.data.languages.includes(data.slug))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
const relatedLanguages = data.comparedWith
  .map((slug) => ({ slug, title: languageTitles.get(slug) ?? slug }))
  .sort((a, b) => a.title.localeCompare(b.title));

const statusStyles: Record<string, string> = {
  active:
    "border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300",
  stable: "border-sky-500/30 bg-sky-500/10 text-sky-700 dark:text-sky-300",
  experimental:
    "border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-300",
  legacy:
    "border-stone-500/30 bg-stone-500/10 text-stone-700 dark:text-stone-300",
  inactive: "border-rose-500/30 bg-rose-500/10 text-rose-700 dark:text-rose-300",
};
const statusClass = statusStyles[data.status] ?? statusStyles.active;

const factCells: Array<{ label: string; value: string; mono: boolean }> = [
  { label: "Status", value: data.status, mono: false },
  {
    label: "Typing",
    value:
      data.typing.discipline +
      (data.typing.strength ? `, ${data.typing.strength}` : ""),
    mono: false,
  },
  { label: "Runtime", value: data.runtime.model, mono: false },
  { label: "Memory", value: data.memory.model, mono: false },
];
if (data.firstReleased) {
  factCells.push({
    label: "First released",
    value: String(data.firstReleased),
    mono: true,
  });
}
if (data.creators.length > 0) {
  factCells.push({
    label: "Creators",
    value: data.creators.join(", "),
    mono: false,
  });
}
if (data.packageManagers.length > 0) {
  factCells.push({
    label: "Package managers",
    value: data.packageManagers.join(", "),
    mono: false,
  });
}
---

<BaseLayout title={data.title} description={data.summary}>
  <article class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <nav
      aria-label="Breadcrumb"
      class="text-sm text-[color:var(--color-fg-subtle)]"
    >
      <a class="hover:text-[color:var(--color-fg)]" href="/languages">Languages</a>
      <span aria-hidden="true" class="px-1.5">/</span>
      <span class="text-[color:var(--color-fg-muted)]">{data.title}</span>
    </nav>

    <header class="mt-6 flex flex-wrap items-start justify-between gap-4">
      <div>
        <p
          class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
        >
          Language profile
        </p>
        <h1
          class="mt-2 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] sm:text-5xl"
        >
          {data.title}
        </h1>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span
          class:list={[
            "rounded-full border px-2.5 py-1 text-xs font-medium uppercase tracking-wide",
            statusClass,
          ]}
        >
          {data.status}
        </span>
        <a
          href={data.officialSite}
          rel="noopener"
          class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs font-medium text-[color:var(--color-fg)] hover:border-[color:var(--color-border-strong)]"
        >
          Official site
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17L17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        {
          data.repository ? (
            <a
              href={data.repository}
              rel="noopener"
              class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs font-medium text-[color:var(--color-fg)] hover:border-[color:var(--color-border-strong)]"
            >
              Repository
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path
                  d="M7 17L17 7M9 7h8v8"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          ) : null
        }
      </div>
    </header>

    <p
      class="mt-4 max-w-3xl text-lg leading-8 text-[color:var(--color-fg-muted)]"
      data-pagefind-meta="summary"
    >
      {data.summary}
    </p>

    <div class="sr-only" aria-hidden="true">
      <span data-pagefind-filter="type">Language</span>
      <span data-pagefind-filter="status">{data.status}</span>
      <span data-pagefind-filter="typing">{data.typing.discipline}</span>
      {
        data.typing.strength && (
          <span data-pagefind-filter="typing">{data.typing.strength}</span>
        )
      }
      <span data-pagefind-filter="runtime">{data.runtime.model}</span>
      <span data-pagefind-filter="memory">{data.memory.model}</span>
      {
        data.paradigms.map((paradigm) => (
          <span data-pagefind-filter="paradigm">{paradigm}</span>
        ))
      }
      {
        data.packageManagers.map((manager) => (
          <span data-pagefind-filter="ecosystem">{manager}</span>
        ))
      }
      {
        data.bestFor.map((fit) => (
          <span data-pagefind-filter="use case">{fit}</span>
        ))
      }
    </div>

    <dl
      class="mt-8 grid gap-px overflow-hidden rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-border)] sm:grid-cols-2 lg:grid-cols-4"
    >
      {
        factCells.map((cell) => (
          <div class="bg-[color:var(--color-surface)] p-4">
            <dt class="text-[0.7rem] font-medium uppercase tracking-wider text-[color:var(--color-fg-subtle)]">
              {cell.label}
            </dt>
            <dd
              class:list={[
                "mt-1.5 text-sm text-[color:var(--color-fg-strong)]",
                cell.mono ? "font-mono" : "",
              ]}
            >
              {cell.value}
            </dd>
          </div>
        ))
      }
    </dl>

    {
      data.paradigms.length > 0 ? (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {data.paradigms.map((p) => (
            <span class="rounded-full bg-[color:var(--color-surface-muted)] px-2.5 py-1 text-xs text-[color:var(--color-fg-muted)]">
              {p}
            </span>
          ))}
        </div>
      ) : null
    }

    <section class="mt-10 grid gap-6 md:grid-cols-2">
      <div
        class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5"
      >
        <h2
          class="flex items-center gap-2 text-base font-semibold text-[color:var(--color-fg-strong)]"
        >
          <span
            aria-hidden="true"
            class="h-2 w-2 rounded-full bg-emerald-500"></span>
          Best fit
        </h2>
        <ul class="mt-3 space-y-1.5 text-sm text-[color:var(--color-fg-muted)]">
          {
            data.bestFor.map((item) => (
              <li class="flex gap-2">
                <span
                  aria-hidden="true"
                  class="mt-1 text-[color:var(--color-accent)]"
                >
                  +
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div
        class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5"
      >
        <h2
          class="flex items-center gap-2 text-base font-semibold text-[color:var(--color-fg-strong)]"
        >
          <span
            aria-hidden="true"
            class="h-2 w-2 rounded-full bg-amber-500"></span>
          Watch points
        </h2>
        <ul class="mt-3 space-y-1.5 text-sm text-[color:var(--color-fg-muted)]">
          {
            data.poorFit.map((item) => (
              <li class="flex gap-2">
                <span aria-hidden="true" class="mt-1 text-amber-500">
                  −
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="content-body mt-12 max-w-3xl">
      <Content />
    </div>

    {
      relatedLanguages.length > 0 && (
        <section class="mt-12">
          <h2 class="text-base font-semibold text-[color:var(--color-fg-strong)]">
            Related languages
          </h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {relatedLanguages.map((related) =>
              languageTitles.has(related.slug) ? (
                <a
                  class="rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1.5 text-sm text-[color:var(--color-fg)] hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                  href={`/languages/${related.slug}`}
                >
                  {related.title}
                </a>
              ) : (
                <span class="rounded-full border border-dashed border-[color:var(--color-border)] px-3 py-1.5 text-sm text-[color:var(--color-fg-subtle)]">
                  {related.title}
                </span>
              ),
            )}
          </div>
        </section>
      )
    }

    {
      comparisonMatches.length > 0 && (
        <section class="mt-10">
          <h2 class="text-base font-semibold text-[color:var(--color-fg-strong)]">
            Comparisons
          </h2>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            {comparisonMatches.map((comparison) => (
              <a
                class="group rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-4 transition-colors hover:border-[color:var(--color-accent)]/60"
                href={`/comparisons/${comparison.data.slug}`}
              >
                <span class="font-medium text-[color:var(--color-fg-strong)] group-hover:text-[color:var(--color-accent)]">
                  {comparison.data.title}
                </span>
                <span class="mt-1 block text-sm leading-6 text-[color:var(--color-fg-muted)]">
                  {comparison.data.summary}
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <SourceList sources={data.sources} lastVerified={data.lastVerified} />
  </article>
</BaseLayout>
