---
import { getCollection } from "astro:content";
import LanguageCard from "../components/language/LanguageCard.astro";
import BrandBanner from "../components/layout/BrandBanner.astro";
import PagefindSearch from "../components/search/PagefindSearch.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const [languages, comparisons, guides, concepts] = await Promise.all([
  getCollection("languages"),
  getCollection("comparisons"),
  getCollection("guides"),
  getCollection("concepts"),
]);

const sortedLanguages = languages.sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const stats = [
  { label: "Languages", value: languages.length, href: "/languages" },
  { label: "Comparisons", value: comparisons.length, href: "/comparisons" },
  { label: "Guides", value: guides.length, href: "/guides" },
  { label: "Concepts", value: concepts.length, href: "/concepts" },
];

const browseSections = [
  {
    title: "Comparisons",
    href: "/comparisons",
    description:
      "Dimensional, tradeoff-first comparisons between related languages.",
    items: comparisons.slice(0, 4).map((c) => ({
      title: c.data.title,
      href: `/comparisons/${c.data.slug}`,
    })),
  },
  {
    title: "Guides",
    href: "/guides",
    description:
      "Decision guides that frame languages by the problem you are solving.",
    items: guides.slice(0, 4).map((g) => ({
      title: g.data.title,
      href: `/guides/${g.data.slug}`,
    })),
  },
  {
    title: "Concepts",
    href: "/concepts",
    description:
      "Cross-language ideas: type systems, runtimes, memory, and tooling.",
    items: concepts.slice(0, 4).map((c) => ({
      title: c.data.title,
      href: `/concepts/${c.data.slug}`,
    })),
  },
];
---

<BaseLayout title="LangIndex">
  <section class="relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,color-mix(in_srgb,var(--color-accent)_10%,transparent),transparent_60%)]"
    >
    </div>
    <div class="mx-auto max-w-6xl px-4 pt-14 pb-12 sm:px-6 sm:pt-20 sm:pb-16">
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <div
            class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-3 py-1 text-xs font-medium text-[color:var(--color-fg-muted)]"
          >
            <span
              class="h-1.5 w-1.5 rounded-full bg-[color:var(--color-accent)]"
            ></span>
            <span>Open source · Self-hosted · Source-backed</span>
          </div>
          <h1
            class="mt-5 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)] sm:text-5xl sm:leading-[1.05]"
          >
            A field guide to <span class="text-[color:var(--color-accent)]"
              >programming languages</span
            >.
          </h1>
          <p
            class="mt-5 max-w-xl text-lg leading-7 text-[color:var(--color-fg-muted)]"
          >
            LangIndex is a quiet, source-backed reference focused on practical
            fit, design tradeoffs, tooling, governance, and examples for
            developers choosing or maintaining languages.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href="/languages"
              class="inline-flex items-center gap-1.5 rounded-md bg-[color:var(--color-accent)] px-4 py-2 text-sm font-semibold text-[#06201d] transition-opacity hover:opacity-90"
            >
              Browse languages
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M5 12h14m-6-6l6 6-6 6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </a>
            <a
              href="/comparisons"
              class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-2 text-sm font-semibold text-[color:var(--color-fg)] transition-colors hover:border-[color:var(--color-border-strong)]"
            >
              View comparisons
            </a>
          </div>
        </div>
        <div class="space-y-4">
          <BrandBanner eager={true} class="shadow-sm" />
          <div
            class="rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5 shadow-sm"
          >
            <PagefindSearch id="homepage-search" label="Search the reference" />
            <p class="mt-3 text-xs text-[color:var(--color-fg-subtle)]">
              Static, client-side search powered by Pagefind. No tracking, no
              account, no remote calls.
            </p>
          </div>
        </div>
      </div>

      <ul
        class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-4"
        aria-label="Site stats"
      >
        {
          stats.map((stat) => (
            <li>
              <a
                href={stat.href}
                class="group block rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-4 py-3 text-[color:var(--color-fg)] transition-colors hover:border-[color:var(--color-accent)]/50"
              >
                <span class="block text-xs uppercase tracking-wider text-[color:var(--color-fg-subtle)]">
                  {stat.label}
                </span>
                <span class="mt-1 flex items-baseline gap-1">
                  <span class="font-mono text-2xl font-semibold text-[color:var(--color-fg-strong)] group-hover:text-[color:var(--color-accent)]">
                    {stat.value}
                  </span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div
      class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between"
    >
      <div>
        <h2
          class="text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]"
        >
          Seed languages
        </h2>
        <p class="mt-1 text-sm text-[color:var(--color-fg-muted)]">
          A small verified set to prove the content model before expanding
          coverage.
        </p>
      </div>
      <a
        class="text-sm font-medium text-[color:var(--color-accent)] underline-offset-4 hover:underline"
        href="/languages">Browse all languages →</a
      >
    </div>
    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {sortedLanguages.map((language) => <LanguageCard language={language} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-4 md:grid-cols-3">
      {
        browseSections.map((section) => (
          <article class="flex flex-col rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5">
            <h3 class="text-base font-semibold text-[color:var(--color-fg-strong)]">
              <a
                class="hover:text-[color:var(--color-accent)]"
                href={section.href}
              >
                {section.title}
              </a>
            </h3>
            <p class="mt-2 text-sm leading-6 text-[color:var(--color-fg-muted)]">
              {section.description}
            </p>
            {section.items.length > 0 && (
              <ul class="mt-4 space-y-1 text-sm">
                {section.items.map((item) => (
                  <li>
                    <a
                      class="text-[color:var(--color-fg)] underline decoration-[color:var(--color-border-strong)] underline-offset-4 hover:decoration-[color:var(--color-accent)] hover:text-[color:var(--color-accent)]"
                      href={item.href}
                    >
                      {item.title}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div
      class="rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-6 sm:p-8"
    >
      <div class="grid gap-6 md:grid-cols-[1.4fr_1fr] md:items-center">
        <div>
          <h2
            class="text-2xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]"
          >
            Maintain your language's page
          </h2>
          <p class="mt-3 text-sm leading-6 text-[color:var(--color-fg-muted)]">
            Every language page is a regular file in this repository. Open a
            pull request to fix a fact, add an example, or expand a tradeoffs
            section. Facts that are not obvious from official docs need a
            citation.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 md:justify-end">
          <a
            href="/contribute"
            class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-accent)] bg-[color:var(--color-accent-bg)] px-4 py-2 text-sm font-semibold text-[color:var(--color-accent-strong)] transition-colors hover:bg-[color:var(--color-accent)]/15"
          >
            How to contribute
          </a>
          <a
            href="https://github.com/dunamismax/langindex"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)] px-4 py-2 text-sm font-semibold text-[color:var(--color-fg)] transition-colors hover:border-[color:var(--color-border-strong)]"
          >
            View repository
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
