---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const concepts = (await getCollection("concepts")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout
  title="Concepts"
  description="Programming language concepts on LangIndex."
>
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <h1 class="text-3xl font-semibold text-stone-950">Concepts</h1>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        concepts.map((concept) => (
          <article class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
            <h2 class="text-xl font-semibold text-stone-950">
              <a
                class="underline-offset-4 hover:underline"
                href={`/concepts/${concept.data.slug}`}
              >
                {concept.data.title}
              </a>
            </h2>
            <p class="mt-3 text-sm leading-6 text-stone-700">
              {concept.data.summary}
            </p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
