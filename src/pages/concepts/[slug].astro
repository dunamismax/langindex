---
import { getCollection, render } from "astro:content";
import SourceList from "../../components/layout/SourceList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const concepts = await getCollection("concepts");
  return concepts.map((concept) => ({
    params: { slug: concept.data.slug },
    props: { concept },
  }));
}

const { concept } = Astro.props;
const { Content } = await render(concept);
---

<BaseLayout title={concept.data.title} description={concept.data.summary}>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <nav
      aria-label="Breadcrumb"
      class="text-sm text-[color:var(--color-fg-subtle)]"
    >
      <a class="hover:text-[color:var(--color-fg)]" href="/concepts">Concepts</a
      >
      <span aria-hidden="true" class="px-1.5">/</span>
      <span class="text-[color:var(--color-fg-muted)]"
        >{concept.data.title}</span
      >
    </nav>
    <p
      class="mt-6 text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
    >
      Concept
    </p>
    <h1
      class="mt-2 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]"
    >
      {concept.data.title}
    </h1>
    <p class="mt-4 text-lg leading-8 text-[color:var(--color-fg-muted)]">
      {concept.data.summary}
    </p>
    <div class="content-body mt-10">
      <Content />
    </div>
    <SourceList
      sources={concept.data.sources}
      lastVerified={concept.data.lastVerified}
    />
  </article>
</BaseLayout>
