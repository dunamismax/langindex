---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About the LangIndex project.">
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <h1 class="text-3xl font-semibold text-stone-950">About LangIndex</h1>
    <div class="content-body mt-6 text-stone-700">
      <p>
        LangIndex is an open source, self-hosted reference for programming
        languages. Its goal is to help developers compare languages by practical
        fit, constraints, tooling, governance, and tradeoffs.
      </p>
      <p>
        The repository is the source of truth. Content changes should arrive
        through normal pull requests, with factual claims backed by official
        sources whenever possible.
      </p>
    </div>
  </section>
</BaseLayout>
