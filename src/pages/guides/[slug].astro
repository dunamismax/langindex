---
import { getCollection, render } from "astro:content";
import SourceList from "../../components/layout/SourceList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<BaseLayout title={guide.data.title} description={guide.data.summary}>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wider text-teal-800">
      Guide
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-normal text-stone-950">
      {guide.data.title}
    </h1>
    <p class="mt-4 text-lg leading-8 text-stone-700">{guide.data.summary}</p>
    <div class="content-body mt-10">
      <Content />
    </div>
    <SourceList
      sources={guide.data.sources}
      lastVerified={guide.data.lastVerified}
    />
  </article>
</BaseLayout>
