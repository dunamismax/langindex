---
import { getCollection, render } from "astro:content";
import SourceList from "../../components/layout/SourceList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((guide) => ({
    params: { slug: guide.data.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<BaseLayout title={guide.data.title} description={guide.data.summary}>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <nav
      aria-label="Breadcrumb"
      class="text-sm text-[color:var(--color-fg-subtle)]"
    >
      <a class="hover:text-[color:var(--color-fg)]" href="/guides">Guides</a>
      <span aria-hidden="true" class="px-1.5">/</span>
      <span class="text-[color:var(--color-fg-muted)]">{guide.data.title}</span>
    </nav>
    <p
      class="mt-6 text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]"
    >
      Guide
    </p>
    <h1
      class="mt-2 text-4xl font-semibold tracking-tight text-[color:var(--color-fg-strong)]"
    >
      {guide.data.title}
    </h1>
    <p class="mt-4 text-lg leading-8 text-[color:var(--color-fg-muted)]">
      {guide.data.summary}
    </p>
    <div class="content-body mt-10">
      <Content />
    </div>
    <SourceList
      sources={guide.data.sources}
      lastVerified={guide.data.lastVerified}
    />
  </article>
</BaseLayout>
