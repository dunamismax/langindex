---
import "../styles/global.css";
import ThemeToggle from "../components/layout/ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "LangIndex is a self-hosted reference for programming languages.",
} = Astro.props;
const pageTitle = title === "LangIndex" ? title : `${title} | LangIndex`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const siteUrl = new URL("/", canonicalUrl).toString();
const shareImage = new URL("/brand/langindex-logo-512.png", canonicalUrl);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description,
  url: canonicalUrl.toString(),
  isPartOf: {
    "@type": "WebSite",
    name: "LangIndex",
    url: siteUrl,
    potentialAction: {
      "@type": "SearchAction",
      target: `${siteUrl}?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
};
const structuredDataJson = JSON.stringify(structuredData).replaceAll(
  "<",
  "\\u003c",
);
const navItems = [
  { href: "/languages", label: "Languages" },
  { href: "/comparisons", label: "Comparisons" },
  { href: "/guides", label: "Guides" },
  { href: "/concepts", label: "Concepts" },
  { href: "/about", label: "About" },
];
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(`${href}/`);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:site_name" content="LangIndex" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={shareImage.toString()} />
    <meta property="og:image:alt" content="LangIndex" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage.toString()} />
    <meta name="color-scheme" content="dark light" />
    <meta
      name="theme-color"
      content="#0d1117"
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="LangIndex updates"
      href="/rss.xml"
    />
    <title>{pageTitle}</title>
    <script
      type="application/ld+json"
      is:inline
      set:html={structuredDataJson}
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("langindex-theme");
          var theme = stored === "light" || stored === "dark" ? stored : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
  </head>
  <body class="text-[color:var(--color-fg)]">
    <a href="#main" class="skip-link">Skip to content</a>
    <header
      class="sticky top-0 z-20 border-b border-[color:var(--color-border)] backdrop-blur-md bg-[color:var(--color-bg-elevated)]"
      data-pagefind-ignore
    >
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3.5 sm:px-6"
      >
        <a
          href="/"
          class="group flex items-center gap-2 text-[color:var(--color-fg-strong)]"
          aria-label="LangIndex home"
        >
          <img
            src="/brand/langindex-logo-64.png"
            alt=""
            width="64"
            height="64"
            class="h-7 w-7 rounded-md border border-[color:var(--color-border-strong)] shadow-sm transition-colors group-hover:border-[color:var(--color-accent)]"
            decoding="async"
          />
          <span class="text-base font-semibold tracking-tight">LangIndex</span>
        </a>
        <nav
          aria-label="Primary"
          class="hidden items-center gap-0.5 text-sm text-[color:var(--color-fg-muted)] md:flex"
        >
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "rounded-md px-3 py-1.5 transition-colors hover:bg-[color:var(--color-surface-muted)] hover:text-[color:var(--color-fg-strong)]",
                  isActive(item.href)
                    ? "text-[color:var(--color-fg-strong)] bg-[color:var(--color-surface-muted)]"
                    : "",
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="flex items-center gap-2">
          <a
            href="https://github.com/dunamismax/langindex"
            class="hidden rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] px-2.5 py-1.5 text-xs font-medium text-[color:var(--color-fg-muted)] transition-colors hover:border-[color:var(--color-border-strong)] hover:text-[color:var(--color-fg-strong)] sm:inline-flex"
            aria-label="View on GitHub"
            rel="noopener"
          >
            GitHub
          </a>
          <ThemeToggle />
          <button
            type="button"
            data-mobile-nav-toggle
            aria-expanded="false"
            aria-controls="mobile-nav"
            class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-[color:var(--color-fg-muted)] transition-colors hover:text-[color:var(--color-fg-strong)] md:hidden"
          >
            <span class="sr-only">Toggle navigation</span>
            <svg
              data-mobile-nav-icon-open
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 7h16M4 12h16M4 17h16"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
            <svg
              data-mobile-nav-icon-close
              class="hidden"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M6 6l12 12M18 6L6 18"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"></path>
            </svg>
          </button>
        </div>
      </div>
      <nav
        id="mobile-nav"
        aria-label="Mobile"
        data-mobile-nav
        hidden
        class="border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)] md:hidden"
      >
        <ul
          class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 text-sm sm:px-6"
        >
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    "block rounded-md px-3 py-2 text-[color:var(--color-fg-muted)] hover:bg-[color:var(--color-surface-muted)] hover:text-[color:var(--color-fg-strong)]",
                    isActive(item.href)
                      ? "text-[color:var(--color-fg-strong)] bg-[color:var(--color-surface-muted)]"
                      : "",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <footer
      class="mt-16 border-t border-[color:var(--color-border)] bg-[color:var(--color-bg-elevated)]"
      data-pagefind-ignore
    >
      <div
        class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-10 sm:px-6 md:flex-row md:items-start md:justify-between"
      >
        <div class="max-w-md">
          <div class="flex items-center gap-2">
            <img
              src="/brand/langindex-logo-64.png"
              alt=""
              width="64"
              height="64"
              class="h-6 w-6 rounded-md border border-[color:var(--color-border-strong)]"
              loading="lazy"
              decoding="async"
            />
            <span class="font-semibold text-[color:var(--color-fg-strong)]"
              >LangIndex</span
            >
          </div>
          <p class="mt-3 text-sm leading-6 text-[color:var(--color-fg-muted)]">
            A self-hosted, source-backed reference for programming languages.
            Content is community-maintained and licensed CC-BY-SA-4.0.
          </p>
        </div>
        <nav
          aria-label="Footer"
          class="grid grid-cols-2 gap-x-10 gap-y-2 text-sm"
        >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/languages">Languages</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/comparisons">Comparisons</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/guides">Guides</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/concepts">Concepts</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/about">About</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/contribute">Contribute</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="https://github.com/dunamismax/langindex"
            rel="noopener">GitHub</a
          >
          <a
            class="text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg-strong)]"
            href="/rss.xml">RSS</a
          >
        </nav>
      </div>
      <div
        class="border-t border-[color:var(--color-border)] py-4 text-center text-xs text-[color:var(--color-fg-subtle)]"
      >
        Code GPL-3.0 / Content CC-BY-SA-4.0
      </div>
    </footer>
    <script>
      const toggle = document.querySelector("[data-mobile-nav-toggle]");
      const panel = document.querySelector("[data-mobile-nav]");
      const iconOpen = document.querySelector("[data-mobile-nav-icon-open]");
      const iconClose = document.querySelector("[data-mobile-nav-icon-close]");
      if (toggle && panel) {
        toggle.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          const next = !expanded;
          toggle.setAttribute("aria-expanded", String(next));
          (panel as HTMLElement).hidden = !next;
          iconOpen?.classList.toggle("hidden", next);
          iconClose?.classList.toggle("hidden", !next);
        });
      }
    </script>
  </body>
</html>
