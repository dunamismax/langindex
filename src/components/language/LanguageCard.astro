---
import type { CollectionEntry } from "astro:content";

interface Props {
  language: CollectionEntry<"languages">;
}

const { language } = Astro.props;
const data = language.data;

const statusStyles: Record<string, string> = {
  active:
    "border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300",
  stable:
    "border-sky-500/30 bg-sky-500/10 text-sky-700 dark:text-sky-300",
  experimental:
    "border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-300",
  legacy:
    "border-stone-500/30 bg-stone-500/10 text-stone-700 dark:text-stone-300",
  inactive:
    "border-rose-500/30 bg-rose-500/10 text-rose-700 dark:text-rose-300",
};
const statusClass = statusStyles[data.status] ?? statusStyles.active;
const topParadigms = data.paradigms.slice(0, 3);
---

<article
  class="group relative h-full overflow-hidden rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] p-5 transition-all hover:border-[color:var(--color-accent)]/60 hover:shadow-lg hover:shadow-black/5"
>
  <a
    href={`/languages/${data.slug}`}
    class="absolute inset-0 z-10"
    aria-label={`Open ${data.title}`}></a>
  <div class="relative flex flex-col gap-3">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <h2
          class="text-lg font-semibold tracking-tight text-[color:var(--color-fg-strong)] group-hover:text-[color:var(--color-accent)]"
        >
          {data.title}
        </h2>
        {
          data.firstReleased ? (
            <p class="mt-0.5 text-xs text-[color:var(--color-fg-subtle)] font-mono">
              since {data.firstReleased}
            </p>
          ) : null
        }
      </div>
      <span
        class:list={[
          "shrink-0 rounded-full border px-2 py-0.5 text-[0.7rem] font-medium uppercase tracking-wide",
          statusClass,
        ]}
      >
        {data.status}
      </span>
    </div>
    <p class="text-sm leading-6 text-[color:var(--color-fg-muted)]">
      {data.summary}
    </p>
    <dl class="mt-1 grid grid-cols-3 gap-3 border-t border-[color:var(--color-border)] pt-3 text-xs">
      <div>
        <dt class="text-[color:var(--color-fg-subtle)]">Typing</dt>
        <dd class="mt-0.5 font-medium text-[color:var(--color-fg)]">
          {data.typing.discipline}
        </dd>
      </div>
      <div>
        <dt class="text-[color:var(--color-fg-subtle)]">Runtime</dt>
        <dd class="mt-0.5 font-medium text-[color:var(--color-fg)]">
          {data.runtime.model}
        </dd>
      </div>
      <div>
        <dt class="text-[color:var(--color-fg-subtle)]">Memory</dt>
        <dd class="mt-0.5 font-medium text-[color:var(--color-fg)]">
          {data.memory.model}
        </dd>
      </div>
    </dl>
    {
      topParadigms.length > 0 ? (
        <div class="flex flex-wrap gap-1.5">
          {topParadigms.map((p) => (
            <span class="rounded-full bg-[color:var(--color-surface-muted)] px-2 py-0.5 text-[0.7rem] text-[color:var(--color-fg-muted)]">
              {p}
            </span>
          ))}
        </div>
      ) : null
    }
  </div>
</article>
