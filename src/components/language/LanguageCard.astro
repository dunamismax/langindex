---
import type { CollectionEntry } from "astro:content";

interface Props {
  language: CollectionEntry<"languages">;
}

const { language } = Astro.props;
const data = language.data;
---

<article class="rounded-lg border border-stone-200 bg-white p-5 shadow-sm">
  <div class="flex flex-col gap-3">
    <div class="flex items-start justify-between gap-4">
      <h2 class="text-xl font-semibold text-stone-950">
        <a
          class="underline-offset-4 hover:underline"
          href={`/languages/${data.slug}`}>{data.title}</a
        >
      </h2>
      <span
        class="rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-800"
      >
        {data.status}
      </span>
    </div>
    <p class="text-sm leading-6 text-stone-700">{data.summary}</p>
    <dl class="grid gap-3 text-sm sm:grid-cols-3">
      <div>
        <dt class="font-medium text-stone-950">Typing</dt>
        <dd class="text-stone-700">{data.typing.discipline}</dd>
      </div>
      <div>
        <dt class="font-medium text-stone-950">Runtime</dt>
        <dd class="text-stone-700">{data.runtime.model}</dd>
      </div>
      <div>
        <dt class="font-medium text-stone-950">Memory</dt>
        <dd class="text-stone-700">{data.memory.model}</dd>
      </div>
    </dl>
  </div>
</article>
