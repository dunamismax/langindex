---
interface Props {
  id?: string;
  label?: string;
  lazy?: boolean;
}

const {
  id = "site-search",
  label = "Search LangIndex",
  lazy = false,
} = Astro.props;
const lazyLoaderScript = `
  (function () {
    var loaded = false;
    function loadPagefind() {
      if (loaded || document.querySelector("script[data-pagefind-ui]")) return;
      loaded = true;

      var stylesheet = document.createElement("link");
      stylesheet.rel = "stylesheet";
      stylesheet.href = "/pagefind/pagefind-component-ui.css";
      document.head.appendChild(stylesheet);

      var script = document.createElement("script");
      script.type = "module";
      script.src = "/pagefind/pagefind-component-ui.js";
      script.dataset.pagefindUi = "true";
      document.head.appendChild(script);
    }

    var panels = document.querySelectorAll("[data-pagefind-lazy]");
    panels.forEach(function (panel) {
      panel.addEventListener("focusin", loadPagefind, { once: true });
      panel.addEventListener("pointerenter", loadPagefind, { once: true });
    });

    var schedule =
      window.requestIdleCallback ||
      function (callback) {
        return window.setTimeout(callback, 800);
      };
    schedule(loadPagefind);
  })();
`;
---

<section
  aria-labelledby={`${id}-label`}
  class="pagefind-panel"
  data-pagefind-lazy={lazy ? "" : undefined}
>
  {
    !lazy && (
      <>
        <link href="/pagefind/pagefind-component-ui.css" rel="stylesheet" />
        <script
          src="/pagefind/pagefind-component-ui.js"
          type="module"
          is:inline
        />
      </>
    )
  }
  <div class="flex items-center justify-between gap-3">
    <h2
      id={`${id}-label`}
      class="text-sm font-semibold uppercase tracking-wider text-[color:var(--color-fg-strong)]"
    >
      {label}
    </h2>
    <span
      class="hidden rounded border border-[color:var(--color-border)] bg-[color:var(--color-surface-muted)] px-1.5 py-0.5 font-mono text-[0.7rem] text-[color:var(--color-fg-subtle)] sm:inline-block"
      >Pagefind</span
    >
  </div>
  <div id={id} class="mt-3">
    <pagefind-searchbox></pagefind-searchbox>
  </div>
  {lazy && <script is:inline set:html={lazyLoaderScript} />}
</section>
